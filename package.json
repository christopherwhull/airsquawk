{
  "name": "airsquawk",
  "version": "2.1.3",
  "description": "Aircraft Dashboard — Turn ADS-B data from a PiAware receiver into real-time flight intelligence and analytics for operations, monitoring, and research.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:cluster": "node server-cluster.js",
    "start:cluster:dev": "NODE_ENV=development node server-cluster.js",
    "dev": "node server.js",
    "geotiff": "node geotiff-server.js",
    "start:all": "concurrently \"npm start\" \"npm run geotiff\"",
    "proxy:tiles": "node tile-proxy-server.js",
    "precache:tiles": "node tools/precache-tiles.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:heatmap-minimal": "jest heatmap-minimal.test.js",
    "restart:windows": "python tools/manage-services.py restart --wait --timeout 30",
    "restart:unix": "bash restart-server.sh",
    "check-server": "node tools/check_server_restart.js",
    "restart:node": "python tools/restart-server.py",
    "restart:auto": "node tools/check_and_restart_server.js --auto-restart",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "start:pm2:dev": "pm2 start ecosystem.config.js --env development",
    "stop:pm2": "pm2 stop ecosystem.config.js",
    "restart:pm2": "pm2 restart ecosystem.config.js",
    "restart:env": "pm2 restart aircraft-dashboard && pm2 restart websocket-server && pm2 restart tile-proxy-server",
    "delete:pm2": "pm2 delete ecosystem.config.js",
    "status:pm2": "pm2 status",
    "logs:pm2": "pm2 logs aircraft-dashboard",
    "monit:pm2": "pm2 monit",
    "restart:headless": "python tools/manage-services.py restart --wait --timeout 30",
    "start:influxdb": "cmd /c \"start \"\"InfluxDB\"\" \"C:\\influxdb3-core-3.7.0-windows_amd64\\influxdb3.exe\" serve --node-id airsquawk --data-dir \"C:\\Users\\chris\\aircraft-dashboard-new\\influxdb_data\" --auth-token \"apiv3_uYwFVXLMYNcxSvy_inEqBriWTdzGb11WWMFVi646AbcyucrNmkWf8Uc2Nlu3t8lUykV3TTQYZJQLraHtcnOkeg\"\"",
    "start:influxdb:foreground": "\"C:\\influxdb3-core-3.7.0-windows_amd64\\influxdb3.exe\" serve --node-id airsquawk --data-dir \\\"C:\\Users\\chris\\aircraft-dashboard-new\\influxdb_data\\\"",
    "services:start": "python tools/manage-services.py start",
    "services:stop": "python tools/manage-services.py stop",
    "services:restart": "python tools/manage-services.py restart",
    "services:status": "python tools/manage-services.py status",
    "test:all": "node tools/test-all.js",
    "test:clean-slate": "node tools/test-clean-slate.js",
    "test:leaflet": "node tools/leaflet-test.js",
    "test:leaflet:full": "node tools/leaflet-test.js \"http://localhost:3002/heatmap-leaflet.html\" screenshots/testplan/leaflet-test-full --select-overlays --collect-popups --ignore-console=mesonet.agron.iastate.edu/cache/tile.py/.*sfc_analysis/.* --ignore-console=http://localhost:3002/api/v2logos/.* --run-id=full",
    "test:leaflet:tabs": "node tools/leaflet-test.js \"http://localhost:3002/\" screenshots/testplan/leaflet-test-tabs --tabs --run-id=tabs",
    "test:leaflet:ci": "node tools/leaflet-test.js \"http://localhost:3002/\" screenshots/testplan/leaflet-test-ci --tabs --run-id=ci --check-reuse --reuse-repeats=3 --reuse-threshold=0.9 --assert-v2logo --assert-reuse --assert-no-304 --max-304=1 --assert-airline-db-storage --max-airline-db-age-min=60",
    "test:page-errors": "node check-page-errors.js",
    "test:leaflet:tabs:agg": "npm run test:leaflet:tabs && node tools/leaflet-tabs-aggregate.js screenshots/testplan/leaflet-test-tabs/tabs-time-summary.json",
    "validate-config": "node validate-config.js",
    "validate:server": "node -c server.js",
    "create-buckets": "node tools/create-bucket.js",
    "backup-buckets": "node tools/backup-buckets.js backup",
    "restore-buckets": "node tools/backup-buckets.js restore",
    "clean-backups": "node tools/backup-buckets.js clean",
    "backup-status": "node tools/backup-buckets.js status",
    "enable-git-hooks": "git config core.hooksPath .githooks"
  },
  "devNotes": {
    "scriptShellPreference": "python",
    "note": "Do not add new PowerShell scripts (.ps1) for cross-platform helpers; prefer Python scripts and call them from npm scripts using 'python <script>'. This keeps tooling cross-platform and avoids accidental service restarts on Windows when other tools (e.g. MinIO) are managed separately."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "acorn": "^8.15.0",
    "archiver": "^7.0.1",
    "aws-sdk": "^2.814.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.0.0",
    "body-parser": "^2.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.17.1",
    "geotiff": "^2.1.4-beta.1",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "proj4": "^2.20.2",
    "puppeteer": "^24.31.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.0.1",
    "socket.io-client": "^4.7.5",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
